Query 1 — Core PowerShell execution baseline (all 6 groups)
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.process="*-enc*"              OR Processes.process="*-EncodedCommand*"
            OR Processes.process="*-nop*"           OR Processes.process="*-noprofile*"
            OR Processes.process="*-w hidden*"      OR Processes.process="*-WindowStyle Hidden*"
            OR Processes.process="*bypass*"
            OR Processes.process="*IEX*"            OR Processes.process="*Invoke-Expression*"
            OR Processes.process="*Net.WebClient*"
            OR Processes.process="*DownloadString*" OR Processes.process="*DownloadFile*"
            OR Processes.process="*FromBase64String*"
            OR Processes.process="*Invoke-Command*"
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.parent_process
        Processes.process_id Processes.parent_process_id
| `drop_dm_object_name("Processes")`
| eval technique="T1059.001"
| eval threat_groups="G0049 | G0059 | G0064 | G0069 | G0087 | G1044"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| sort -count
| table host, user, process_name, process, parent_process_name, count, first_seen, last_seen, technique, threat_groups

Query 2 — OilRig (G0049): DNS tunnelling + POWRUNER/QUADAGENT
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.process="*Resolve-DnsName*"
            OR Processes.process="*System.Net.Dns*"
            OR Processes.process="*nslookup*"
            OR Processes.process="*dns*txt*"
            OR Processes.process="*QUADAGENT*"
            OR Processes.process="*POWRUNER*"
            OR Processes.process="*update.aspx*"
            OR Processes.process="*Start-Process*"
            OR (Processes.process="*Invoke-WebRequest*" AND Processes.process="*-enc*")
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.process_id
| `drop_dm_object_name("Processes")`
| eval group="G0049 - OilRig / APT34 / Hazel Sandstorm"
| eval technique="T1059.001 + T1071.004 (DNS C2)"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table first_seen, last_seen, host, user, process, parent_process_name, group, technique, count
| sort -count

Query 3 — Magic Hound (G0059) + APT42 (G1044): Office-spawned PS download cradles
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.parent_process_name="WINWORD.EXE"
            OR Processes.parent_process_name="EXCEL.EXE"
            OR Processes.parent_process_name="OUTLOOK.EXE"
            OR Processes.parent_process_name="mshta.exe"
            OR Processes.parent_process_name="wscript.exe"
            OR Processes.parent_process_name="cscript.exe"
        )
        AND (
            Processes.process="*IEX*"               OR Processes.process="*Invoke-Expression*"
            OR Processes.process="*Net.WebClient*"  OR Processes.process="*DownloadString*"
            OR Processes.process="*-enc*"           OR Processes.process="*-EncodedCommand*"
            OR Processes.process="*Dropbox*"        OR Processes.process="*drive.google*"
            OR Processes.process="*OneDrive*"       OR Processes.process="*Backblaze*"
            OR Processes.process="*ipfs*"
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.process_id Processes.parent_process_id
| `drop_dm_object_name("Processes")`
| eval groups="G0059 - Magic Hound / APT35 | G1044 - APT42"
| eval technique="T1059.001 - Office-spawned PowerShell"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table first_seen, last_seen, host, user, process, parent_process_name, groups, technique, count
| sort -count

Query 4 — APT33 (G0064): Empire framework + POWERTON + obfuscation
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.process="*Empire*"
            OR Processes.process="*POWERTON*"
            OR Processes.process="*Invoke-Empire*"
            OR Processes.process="*Get-System*"
            OR Processes.process="*Invoke-Mimikatz*"
            OR Processes.process="*Invoke-Shellcode*"
            OR Processes.process="*Net.Sockets.TCPClient*"
            OR Processes.process="*LaZagne*"
            OR Processes.process="*PupyRAT*"
            OR (
                Processes.process="*-nop*"
                AND Processes.process="*-w hidden*"
                AND Processes.process="*-c*"
            )
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.process_id
| `drop_dm_object_name("Processes")`
| eval group="G0064 - APT33 / Elfin / Peach Sandstorm / HOLMIUM"
| eval technique="T1059.001"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table first_seen, last_seen, host, user, process, parent_process_name, group, technique, count
| sort -count

Query 5 — MuddyWater (G0069): POWERSTATS / PowGoop / Telegram C2
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.process="*POWERSTATS*"
            OR Processes.process="*PowGoop*"
            OR Processes.process="*Mori*"
            OR Processes.process="*PhonyC2*"
            OR Processes.process="*MuddyC2*"
            OR Processes.process="*DarkBeatC2*"
            OR Processes.process="*api.telegram.org*"
            OR Processes.process="*Small Sieve*"
            OR Processes.process="*Starwhale*"
            OR Processes.process="*Chisel*"
            OR Processes.process="*Fast Reverse Proxy*"
            OR (Processes.process="*[char]*" AND Processes.process="*-join*")
            OR (Processes.process="*rundll32*" AND Processes.process="*powershell*")
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.process_id
| `drop_dm_object_name("Processes")`
| eval group="G0069 - MuddyWater / Seedworm / MERCURY / Static Kitten"
| eval technique="T1059.001"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table first_seen, last_seen, host, user, process, parent_process_name, group, technique, count
| sort -count

Query 6 — APT39 (G0087): Lateral movement + credential harvesting
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.process="*Invoke-Command*"
            OR Processes.process="*Enter-PSSession*"
            OR Processes.process="*New-PSSession*"
            OR Processes.process="*Invoke-WMIMethod*"
            OR Processes.process="*Get-WMIObject*"
            OR Processes.process="*Mimikatz*"
            OR Processes.process="*sekurlsa*"
            OR Processes.process="*comsvcs.dll*"
            OR Processes.process="*MiniDump*"
            OR Processes.process="*ProcDump*"
            OR Processes.process="*Net.Sockets*"
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.process_id
| `drop_dm_object_name("Processes")`
| eval group="G0087 - APT39 / Chafer / Remix Kitten"
| eval technique="T1059.001 - Lateral Movement + Credential Access"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table first_seen, last_seen, host, user, process, parent_process_name, group, technique, count
| sort -count

Query 7 — Malware datamodel: Symantec EP AV detections (all groups)
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Malware.Malware_Attacks
    where
        (
            Malware_Attacks.file_name="*powershell*"
            OR Malware_Attacks.process="*powershell*"
            OR Malware_Attacks.signature="*powershell*"
            OR Malware_Attacks.signature="*POWERSTATS*"
            OR Malware_Attacks.signature="*PowGoop*"
            OR Malware_Attacks.signature="*Empire*"
            OR Malware_Attacks.signature="*Mimikatz*"
            OR Malware_Attacks.signature="*POWRUNER*"
            OR Malware_Attacks.signature="*encoded*"
            OR Malware_Attacks.signature="*obfuscat*"
        )
    by
        Malware_Attacks.dest Malware_Attacks.user Malware_Attacks.file_name
        Malware_Attacks.process Malware_Attacks.signature Malware_Attacks.action
        Malware_Attacks.vendor_product
| `drop_dm_object_name("Malware_Attacks")`
| eval technique="T1059.001"
| eval threat_groups="G0049 | G0059 | G0064 | G0069 | G0087 | G1044"
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table first_seen, last_seen, dest, user, file_name, signature, action, vendor_product, technique, threat_groups, count
| sort -count

Query 8 — Aggregated threat hunt with risk scoring (all groups, all indicators)
This is your single-pane master hunt query across all groups with dynamic attribution and risk scoring.
spl| tstats summariesonly=true allow_old_summaries=true count min(_time) as first_seen max(_time) as last_seen
    from datamodel=Endpoint.Processes
    where
        (Processes.process_name="powershell.exe" OR Processes.process_name="pwsh.exe")
        AND (
            Processes.process="*-enc*"              OR Processes.process="*-EncodedCommand*"
            OR Processes.process="*-nop*"           OR Processes.process="*bypass*"
            OR Processes.process="*-w hidden*"
            OR Processes.process="*IEX*"            OR Processes.process="*Invoke-Expression*"
            OR Processes.process="*Net.WebClient*"  OR Processes.process="*DownloadString*"
            OR Processes.process="*DownloadFile*"   OR Processes.process="*FromBase64String*"
            OR Processes.process="*Invoke-Command*" OR Processes.process="*Enter-PSSession*"
            OR Processes.process="*New-PSSession*"  OR Processes.process="*Resolve-DnsName*"
            OR Processes.process="*Mimikatz*"       OR Processes.process="*sekurlsa*"
            OR Processes.process="*Empire*"         OR Processes.process="*POWERSTATS*"
            OR Processes.process="*PowGoop*"        OR Processes.process="*api.telegram.org*"
            OR Processes.process="*POWRUNER*"       OR Processes.process="*Invoke-Shellcode*"
            OR Processes.process="*Invoke-WMIMethod*"
            OR Processes.process="*LaZagne*"        OR Processes.process="*comsvcs.dll*"
            OR Processes.process="*Dropbox*"        OR Processes.process="*OneDrive*"
            OR Processes.process="*drive.google*"   OR Processes.process="*Backblaze*"
            OR Processes.process="*ipfs*"
        )
    by
        Processes.host Processes.user Processes.process_name Processes.process
        Processes.parent_process_name Processes.parent_process
        Processes.process_id Processes.parent_process_id
| `drop_dm_object_name("Processes")`
| eval risk_score=case(
    match(process,"(?i)mimikatz|sekurlsa|comsvcs|MiniDump|ProcDump"),                                  90,
    match(process,"(?i)POWERSTATS|PowGoop|Empire|Invoke-Shellcode|POWRUNER"),                          85,
    match(process,"(?i)-enc|-EncodedCommand") AND match(process,"(?i)bypass|hidden|nop"),              75,
    match(process,"(?i)IEX|Invoke-Expression") AND match(process,"(?i)Net.WebClient|DownloadString"),  70,
    match(process,"(?i)Dropbox|OneDrive|drive.google|Backblaze|ipfs"),                                 68,
    match(process,"(?i)api.telegram.org"),                                                             65,
    match(process,"(?i)Invoke-Command|Enter-PSSession|New-PSSession"),                                 60,
    match(process,"(?i)Resolve-DnsName|System.Net.Dns"),                                               55,
    true(),                                                                                            40
)
| eval attributed_group=case(
    match(process,"(?i)POWRUNER|QUADAGENT|Resolve-DnsName"),
        "G0049 - OilRig / APT34",
    match(process,"(?i)POWERSTATS|PowGoop|Mori|PhonyC2|DarkBeatC2|api.telegram.org|Chisel"),
        "G0069 - MuddyWater / Seedworm",
    match(process,"(?i)Empire|POWERTON|LaZagne|Invoke-Shellcode|Net.Sockets.TCPClient"),
        "G0064 - APT33 / Elfin",
    match(parent_process_name,"(?i)WINWORD|EXCEL|OUTLOOK|mshta|wscript|cscript")
        AND match(process,"(?i)Dropbox|OneDrive|drive.google|Backblaze|ipfs"),
        "G0059 / G1044 - Magic Hound / APT42",
    match(parent_process_name,"(?i)WINWORD|EXCEL|OUTLOOK|mshta|wscript|cscript"),
        "G0059 - Magic Hound / G1044 - APT42 (unconfirmed cloud C2)",
    match(process,"(?i)Enter-PSSession|New-PSSession") AND match(process,"(?i)Mimikatz|comsvcs"),
        "G0087 - APT39 / Chafer",
    true(),
        "Unknown - Investigate"
)
| eval risk_level=case(risk_score>=85,"CRITICAL", risk_score>=70,"HIGH", risk_score>=55,"MEDIUM", true(),"LOW")
| eval first_seen=strftime(first_seen,"%Y-%m-%d %H:%M:%S")
| eval last_seen=strftime(last_seen,"%Y-%m-%d %H:%M:%S")
| table risk_level, risk_score, attributed_group, host, user, process_name,
        process, parent_process_name, count, first_seen, last_seen
| sort -risk_score, -count
